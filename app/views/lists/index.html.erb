

<div class="container">
  <div class="card-category" style="background-image: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url(https://raw.githubusercontent.com/lewagon/fullstack-images/master/uikit/breakfast.jpg)">
    Your movie lists
  </div>

  <h3 class="mb-2">My Lists</h3>

  <ul>
    <% @lists.each do |list| %>
      <li>
        <%= link_to list_path(list), class:"text-decoration-none" do %>
          <% if list.photo.attached? %>
            <%= cl_image_tag list.photo.key, height: 120, width: 200, crop: :fill %>
          <% end %>

          <%= list.name %>
        <% end %>

        <%= link_to "delete", list_path(list), data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to remove the list #{list.name}"}, class: 'text-danger' %></small>

      </li>
    <% end %>
  </ul>

  <%= link_to "Create a movie list", new_list_path, class: "btn btn-primary" %>
</div>
